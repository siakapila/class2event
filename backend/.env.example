# ------------------------
# 🔐 REQUIRED CREDENTIALS
# ------------------------

# The PostgreSQL connection URI
DATABASE_URL="postgresql://postgres:REPLACE_WITH_PASSWORD@localhost:5432/class2event"

# The secret used to sign JSON Web Tokens
JWT_SECRET="generate_a_very_secure_random_string_here"

# ------------------------
# 📧 EMAIL SMTP SETTINGS (Optional for Dev, Required for Prod)
# ------------------------
# If left blank, the system will use a generated Ethereal test account automatically
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM='"Class2Event" <noreply@class2event.com>'

# ------------------------
# 🌐 ENVIRONMENT & URLs
# ------------------------
# Environment type (development / production)
NODE_ENV="development"

# Port the backend runs on
PORT=3001

# The URL of the frontend for CORS and Email links
FRONTEND_URL="http://localhost:5173"

# The URL of the backend API for Email callback links
BACKEND_URL="http://localhost:3001"
